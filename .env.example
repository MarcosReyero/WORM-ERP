# ==========================================
# CONFIGURACIÓN DE DESPLIEGUE CON CONTENEDORES
# ==========================================
# Copia este archivo a .env y ajusta los valores según tu entorno

# DATABASE
DB_NAME=inventary
DB_USER=inventary
DB_PASSWORD=changeme
DATABASE_URL=postgres://inventary:changeme@db:5432/inventary

# DJANGO
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,inventory.example.com

# WEB SERVICE
WEB_PORT=8000

# NGINX
NGINX_PORT=80

# EMAIL CONFIGURATION
# Opciones: django.core.mail.backends.console.EmailBackend (development)
#           django.core.mail.backends.smtp.EmailBackend (production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=inventory@erp.local
INVENTORY_ALARM_EMAILS_ENABLED=true

# SMTP (si usas EmailBackend de SMTP)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=password

# LOGGING
LOG_LEVEL=INFO

# ==========================================
# CONFIGURACIÓN DE AUTOMATIZACIÓN
# ==========================================
# ⭐ IMPORTANTE: 
# - Desabilitar en contenedor 'web': INVENTORY_AUTOMATION_ENABLED=false
# - Habilitar en contenedor 'inventory_automation': INVENTORY_AUTOMATION_ENABLED=true
# Esto es manejado automáticamente por docker-compose.yml

# Scheduler polling interval (segundos)
INVENTORY_AUTOMATION_POLL_SECONDS=60

# Intervalo de reconciliación completa (segundos; default 600 = 10 min)
INVENTORY_MINIMUM_STOCK_RECONCILE_SECONDS=600

# Tamaño de lotes en reconciliación
INVENTORY_AUTOMATION_BATCH_SIZE=100

# TTL del lease del scheduler (segundos)
INVENTORY_AUTOMATION_SCHEDULER_LEASE_SECONDS=90

# TTL del lease del digest (segundos)
INVENTORY_AUTOMATION_DIGEST_LEASE_SECONDS=300

# Intervalo de heartbeat dentro de jobs (segundos)
INVENTORY_AUTOMATION_JOB_HEARTBEAT_SECONDS=15

# Minutos máximos a esperar schema ready al arrancar worker
# (sirven para manejo de migraciones)
INVENTORY_AUTOMATION_SCHEMA_WAIT_SECONDS=30

# ==========================================
# HORARIOS DE DIGEST (Digest Config en admin)
# ==========================================
# Estos se configuran en admin (/admin/inventory/minimumstockdigestconfig/)
# pero aquí están los defaults:
#
# INVENTORY_DIGEST_RUN_AT=08:00 (hora del día)
# INVENTORY_DIGEST_FREQUENCY=daily (daily | weekly)
# INVENTORY_DIGEST_RUN_WEEKDAY=0 (0=Monday, 6=Sunday)

# ==========================================
# RESTRICCIONES Y LÍMITES
# ==========================================
# El sistema está diseñado para:
# - Una sola instancia del contenedor 'inventory_automation' activa
# - Base de datos única compartida (SQLite o PostgreSQL)
# - Lease en DB como protección anti-duplicación
#
# Si necesitas escalado multi-worker, considera Celery + Redis o APScheduler externo.
