{
  # En LAN no usamos ACME: se sirve con certificado local (mkcert)
  auto_https off
}

# Dominio LAN (ej: worm.lan). Requiere montar certificados en /etc/caddy/certs.
{$PUBLIC_DOMAIN} {
  encode gzip

  request_body {
    max_size 20MB
  }

  tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem

  reverse_proxy nginx:80
}

